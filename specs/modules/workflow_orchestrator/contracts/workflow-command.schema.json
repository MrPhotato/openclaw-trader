{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowManualTriggerCommand",
  "type": "object",
  "required": ["command_id", "command_type", "initiator", "requested_at"],
  "properties": {
    "command_id": {"type": "string"},
    "command_type": {
      "type": "string",
      "enum": [
        "refresh_strategy",
        "rerun_trade_review",
        "dispatch_once",
        "sync_news",
        "emit_daily_report",
        "retrain_models",
        "replay_window",
        "pause_workflow",
        "resume_workflow"
      ]
    },
    "initiator": {"type": "string"},
    "scope": {"type": "object"},
    "params": {"type": "object"},
    "requested_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
