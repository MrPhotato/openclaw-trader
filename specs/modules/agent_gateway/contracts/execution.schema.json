{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "execution submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "generated_at_utc",
    "trigger_type",
    "decisions"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "strategy_id": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "trigger_type": {
      "type": "string"
    },
    "pm_recheck_requested": {
      "type": "boolean"
    },
    "pm_recheck_reason": {
      "type": "string"
    },
    "tactical_map_update": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "map_refresh_reason",
        "portfolio_posture",
        "desk_focus",
        "risk_bias",
        "coins"
      ],
      "properties": {
        "map_refresh_reason": {
          "type": "string"
        },
        "portfolio_posture": {
          "type": "string"
        },
        "desk_focus": {
          "type": "string"
        },
        "risk_bias": {
          "type": "string"
        },
        "next_review_hint": {
          "type": "string"
        },
        "coins": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "coin",
              "working_posture",
              "base_case",
              "first_entry_plan",
              "preferred_add_condition",
              "preferred_reduce_condition",
              "no_trade_zone",
              "force_pm_recheck_condition",
              "next_focus"
            ],
            "properties": {
              "coin": {
                "type": "string"
              },
              "working_posture": {
                "type": "string"
              },
              "base_case": {
                "type": "string"
              },
              "first_entry_plan": {
                "type": "string",
                "minLength": 1
              },
              "preferred_add_condition": {
                "type": "string"
              },
              "preferred_reduce_condition": {
                "type": "string"
              },
              "reference_take_profit_condition": {
                "type": "string"
              },
              "reference_stop_loss_condition": {
                "type": "string"
              },
              "no_trade_zone": {
                "type": "string"
              },
              "force_pm_recheck_condition": {
                "type": "string"
              },
              "next_focus": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol",
          "action",
          "priority",
          "urgency",
          "valid_for_minutes",
          "reason"
        ],
        "properties": {
          "symbol": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "open",
              "add",
              "reduce",
              "close",
              "flip",
              "wait",
              "hold"
            ]
          },
          "direction": {
            "type": "string",
            "enum": [
              "long",
              "short",
              "flat"
            ]
          },
          "reason": {
            "type": "string"
          },
          "reference_take_profit_condition": {
            "type": "string"
          },
          "reference_stop_loss_condition": {
            "type": "string"
          },
          "size_pct_of_exposure_budget": {
            "type": "number"
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "urgency": {
            "type": "string",
            "enum": [
              "low",
              "normal",
              "high"
            ]
          },
          "valid_for_minutes": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "pm_recheck_requested": {
            "const": true
          }
        },
        "required": [
          "pm_recheck_requested"
        ]
      },
      "then": {
        "required": [
          "pm_recheck_reason"
        ],
        "properties": {
          "pm_recheck_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
