{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "strategy submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "portfolio_mode",
    "target_gross_exposure_band_pct",
    "portfolio_thesis",
    "portfolio_invalidation",
    "flip_triggers",
    "change_summary",
    "targets",
    "scheduled_rechecks"
  ],
  "properties": {
    "portfolio_mode": {
      "type": "string",
      "enum": [
        "normal",
        "defensive",
        "only_reduce",
        "flat"
      ]
    },
    "target_gross_exposure_band_pct": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number"
      }
    },
    "portfolio_thesis": {
      "description": "Structured list of thesis claims (spec 015 FR-001). Each claim tags the evidence it relies on so the submit-gate can audit narrative-over-price bias.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statement", "evidence_type", "evidence_sources"],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1,
            "description": "单句论断。核心论断至少 3 条。"
          },
          "evidence_type": {
            "type": "string",
            "enum": ["price_action", "quant_forecast", "narrative", "regime", "mixed"]
          },
          "evidence_sources": {
            "type": "array",
            "items": {"type": "string"},
            "description": "引用的具体数据点或信号（例如 'Deribit BTC 3M basis 4.8%', 'Polymarket hormuz 82.5%'）。"
          }
        }
      }
    },
    "portfolio_invalidation": {
      "type": "string"
    },
    "flip_triggers": {
      "type": "string"
    },
    "change_summary": {
      "description": "结构化变更摘要（spec 015 FR-002）。`evidence_breakdown` 四项之和必须严格等于 100；`why_no_external_trigger` 在没有外部触发器时必填。",
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "evidence_breakdown"],
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "evidence_breakdown": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "price_action_pct",
            "quant_forecast_pct",
            "narrative_pct",
            "regime_pct"
          ],
          "properties": {
            "price_action_pct": {"type": "number", "minimum": 0, "maximum": 100},
            "quant_forecast_pct": {"type": "number", "minimum": 0, "maximum": 100},
            "narrative_pct": {"type": "number", "minimum": 0, "maximum": 100},
            "regime_pct": {"type": "number", "minimum": 0, "maximum": 100}
          }
        },
        "why_no_external_trigger": {
          "type": ["string", "null"],
          "description": "当 submit-gate 没有命中任何外部触发器 (new_mea_event / price_breach / quant_flip / risk_brake / owner_push) 时，PM 必须用自我质询文本填此字段，否则 submit 被拒 (hesitation_unjustified)。"
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "symbol",
          "state",
          "direction",
          "target_exposure_band_pct",
          "rt_discretion_band_pct",
          "priority"
        ],
        "properties": {
          "symbol": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "disabled",
              "watch",
              "active",
              "only_reduce"
            ]
          },
          "direction": {
            "type": "string",
            "enum": [
              "long",
              "short",
              "flat"
            ]
          },
          "target_exposure_band_pct": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number"
            }
          },
          "rt_discretion_band_pct": {
            "type": "number",
            "minimum": 0
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "symbol": {
                "const": "BTC"
              }
            },
            "required": [
              "symbol"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "symbol": {
                "const": "ETH"
              }
            },
            "required": [
              "symbol"
            ]
          }
        }
      ]
    },
    "scheduled_rechecks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recheck_at_utc",
          "scope",
          "reason"
        ],
        "properties": {
          "recheck_at_utc": {
            "type": "string",
            "format": "date-time"
          },
          "scope": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "price_rechecks": {
      "type": "array",
      "description": "Event-driven (vs time-driven) PM wakes. PriceRecheckMonitor evaluates each subscription every ~30s against runtime_bridge_state.context; satisfaction triggers a one-shot pm_trigger_event. Per-subscription dedup: each (strategy_id, subscription_id) fires at most once per strategy revision.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subscription_id",
          "metric",
          "operator",
          "threshold",
          "scope",
          "reason"
        ],
        "properties": {
          "subscription_id": {
            "type": "string",
            "minLength": 1,
            "description": "Stable PM-authored id; used for dedup keys."
          },
          "metric": {
            "type": "string",
            "minLength": 1,
            "description": "Dotted path under runtime_bridge_state.context, restricted to: market.market.<COIN>.mark_price | market.market.<COIN>.index_price | macro_prices.<symbol>.price."
          },
          "operator": {
            "type": "string",
            "enum": [">=", "<=", ">", "<"]
          },
          "threshold": {
            "type": "number"
          },
          "scope": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
