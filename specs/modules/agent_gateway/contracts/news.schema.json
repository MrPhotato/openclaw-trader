{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "news submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "events"
  ],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "category",
          "summary",
          "impact_level"
        ],
        "properties": {
          "event_id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "impact_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "thesis_alignment": {
            "type": ["string", "null"],
            "enum": [
              "reinforces",
              "weakens",
              "flip_trigger",
              "neutral",
              null
            ],
            "description": "How this event relates to PM's current strategy thesis. 'reinforces' = strengthens thesis (PM may expand); 'weakens' = erodes thesis (PM may reduce); 'flip_trigger' = hits PM's named flip condition (urgent review); 'neutral' = informational only. Omit for events unrelated to any active strategy."
          }
        }
      }
    }
  }
}
