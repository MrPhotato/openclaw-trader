{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw/specs/005/execution-plan.schema.json",
  "title": "ExecutionPlan",
  "type": "object",
  "required": [
    "plan_id",
    "decision_id",
    "action",
    "side"
  ],
  "properties": {
    "plan_id": {"type": "string"},
    "decision_id": {"type": "string"},
    "action": {"type": "string", "enum": ["open", "add", "reduce", "close", "flip", "wait"]},
    "side": {"type": "string", "enum": ["long", "short"]},
    "margin_usd": {"type": ["string", "null"]},
    "notional_usd": {"type": ["string", "null"]},
    "leverage": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
