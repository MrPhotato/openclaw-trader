{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MacroEventSubmission",
  "type": "object",
  "required": ["submission_id", "task_id", "generated_at", "events"],
  "properties": {
    "submission_id": {"type": "string"},
    "task_id": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_key", "category", "severity", "status", "summary"],
        "properties": {
          "event_key": {"type": "string"},
          "category": {"type": "string"},
          "severity": {"type": "string"},
          "status": {"type": "string", "enum": ["active", "resolved", "cancelled"]},
          "summary": {"type": "string"},
          "time_horizon": {"type": "object"},
          "affected_symbols": {"type": "array", "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "object"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
