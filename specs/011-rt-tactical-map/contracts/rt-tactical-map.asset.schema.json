{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RT Tactical Map Asset",
  "type": "object",
  "required": [
    "map_id",
    "strategy_key",
    "created_at_utc",
    "updated_at_utc",
    "map_refresh_reason",
    "portfolio_posture",
    "desk_focus",
    "risk_bias",
    "coins"
  ],
  "properties": {
    "map_id": { "type": "string" },
    "strategy_key": { "type": "string" },
    "created_at_utc": { "type": "string" },
    "updated_at_utc": { "type": "string" },
    "map_refresh_reason": { "type": "string" },
    "portfolio_posture": { "type": "string" },
    "desk_focus": { "type": "string" },
    "risk_bias": { "type": "string" },
    "next_review_hint": { "type": "string" },
    "coins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "coin",
          "working_posture",
          "base_case",
          "first_entry_plan",
          "preferred_add_condition",
          "preferred_reduce_condition",
          "reference_take_profit_condition",
          "reference_stop_loss_condition",
          "no_trade_zone",
          "force_pm_recheck_condition",
          "next_focus"
        ],
        "properties": {
          "coin": { "type": "string" },
          "working_posture": { "type": "string" },
          "base_case": { "type": "string" },
          "first_entry_plan": { "type": "string", "minLength": 1 },
          "preferred_add_condition": { "type": "string" },
          "preferred_reduce_condition": { "type": "string" },
          "reference_take_profit_condition": { "type": "string" },
          "reference_stop_loss_condition": { "type": "string" },
          "no_trade_zone": { "type": "string" },
          "force_pm_recheck_condition": { "type": "string" },
          "next_focus": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
